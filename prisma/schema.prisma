generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  MASTER_ADMIN
  OWNER
  STAFF
}

enum HotelStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PlatformType {
  MAKEMYTRIP
  AGODA
  GOIBIBO
  AIRBNB
  BOOKING_COM
  EXPEDIA
  CLEARTRIP
}

enum PlatformConnectionStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  PENDING
}

enum BookingSourceType {
  INTERNAL
  MAKEMYTRIP
  AGODA
  GOIBIBO
  AIRBNB
  BOOKING_COM
  EXPEDIA
  CLEARTRIP
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  FAILED
  REJECTED
  CHECKED_IN
  CHECKED_OUT
}

enum SyncActionType {
  INVENTORY_UPDATE
  RATE_UPDATE
  BOOKING_CREATE
  BOOKING_CANCEL
  ROOM_TYPE_UPDATE
  RESTRICTION_UPDATE
  FULL_SYNC
}

enum SyncStatus {
  QUEUED
  PROCESSING
  SUCCESS
  FAILED
  PARTIAL_SUCCESS
}

enum InventoryBlockReason {
  NONE
  MAINTENANCE
  OWNER_BLOCK
  BLACKOUT
  CHANNEL_HOLD
}

enum OnboardingStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum HotelRegistrationStatus {
  PENDING_REVIEW
  ACTIVE
  REJECTED
  SUSPENDED
}

enum MediaAssetType {
  PROPERTY_LOGO
  PROPERTY_IMAGE
  GSTIN_DOC
  PAN_DOC
  TRADE_LICENSE_DOC
  ADDRESS_PROOF_DOC
}

enum MediaVisibility {
  PUBLIC
  PRIVATE
}

enum IdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum ReconciliationRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum ReconciliationIssueSeverity {
  LOW
  MEDIUM
  HIGH
}

enum ReconciliationIssueStatus {
  OPEN
  RESOLVED
}

enum ReplayRequestStatus {
  REQUESTED
  PROCESSING
  COMPLETED
  FAILED
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationType {
  ONBOARDING_SUBMITTED
  ONBOARDING_APPROVED
  ONBOARDING_REJECTED
  SYNC_FAILURE
}

model AuthUser {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  emailVerified Boolean       @default(false)
  image         String?
  role          String        @default("OWNER")
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sessions      AuthSession[]
  accounts      AuthAccount[]
  domainUser    User?
}

model AuthSession {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuthAccount {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuthVerification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model User {
  id                   String           @id @default(cuid())
  authUserId           String?          @unique
  name                 String
  email                String           @unique
  passwordHash         String?
  role                 UserRole         @default(OWNER)
  isActive             Boolean          @default(true)
  ownerApprovalStatus  OnboardingStatus @default(DRAFT)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  authUser             AuthUser?                  @relation(fields: [authUserId], references: [id], onDelete: SetNull)
  ownedHotels          Hotel[]                    @relation("HotelOwner")
  memberships          HotelUser[]
  createdBookings      Booking[]                  @relation("BookingCreatedBy")
  ownerProfile         OwnerProfile?
  ownerOnboarding      OwnerOnboarding?
  reviewedOnboardings  OwnerOnboarding[]          @relation("OnboardingReviewedBy")
  propertyRegistrations PropertyRegistration[]    @relation("PropertyOwner")
  mediaAssets          MediaAsset[]               @relation("MediaOwner")
  approvalActions      ApprovalAuditLog[]         @relation("ApprovalActor")
  idempotencyKeys      IdempotencyKey[]
  reconciliationRuns   SyncReconciliationRun[]    @relation("ReconciliationTriggeredBy")
  replayRequests       SyncReplayRequest[]        @relation("ReplayRequestedBy")
  notifications        Notification[]

  @@index([ownerApprovalStatus])
  @@index([role])
}

model Hotel {
  id                 String                 @id @default(cuid())
  name               String
  slug               String                 @unique
  description        String?
  status             HotelStatus            @default(ACTIVE)
  registrationStatus HotelRegistrationStatus @default(PENDING_REVIEW)

  ownerId            String
  owner              User                   @relation("HotelOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  phone              String?
  email              String?
  addressLine1       String?
  addressLine2       String?
  city               String?
  state              String?
  country            String?
  postalCode         String?
  timezone           String                 @default("Asia/Kolkata")
  currency           String                 @default("INR")

  checkInTime        String?
  checkOutTime       String?

  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  users              HotelUser[]
  roomTypes          RoomType[]
  ratePlans          RatePlan[]
  inventories        Inventory[]
  platformConfigs    HotelPlatformConfig[]
  bookings           Booking[]
  syncLogs           SyncLog[]
  inventoryEvents    InventoryEvent[]
  propertyRegistration PropertyRegistration?
  mediaAssets        MediaAsset[]           @relation("MediaHotel")
  reconciliationRuns SyncReconciliationRun[]
  reconciliationIssues SyncReconciliationIssue[]
  replayRequests     SyncReplayRequest[]

  @@index([ownerId])
  @@index([status])
  @@index([registrationStatus])
}

model HotelUser {
  id         String   @id @default(cuid())
  hotelId    String
  userId     String
  roleLabel  String?

  hotel      Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@unique([hotelId, userId])
  @@index([hotelId])
  @@index([userId])
}

model RoomType {
  id               String                   @id @default(cuid())
  hotelId          String
  hotel            Hotel                    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  name             String
  slug             String
  description      String?
  baseOccupancy    Int                      @default(2)
  maxOccupancy     Int                      @default(2)
  totalRooms       Int
  basePrice        Decimal                  @db.Decimal(10, 2)

  sizeSqft         Int?
  bedType          String?
  amenities        Json?
  isActive         Boolean                  @default(true)

  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  inventories      Inventory[]
  bookings         Booking[]
  platformMappings RoomTypePlatformMapping[]
  ratePlans        RatePlan[]
  reconciliationIssues SyncReconciliationIssue[]

  @@unique([hotelId, slug])
  @@index([hotelId])
  @@index([hotelId, isActive])
}

model RatePlan {
  id                String    @id @default(cuid())
  hotelId           String
  roomTypeId        String

  name              String
  code              String?
  description       String?

  basePrice         Decimal   @db.Decimal(10, 2)
  minStay           Int       @default(1)
  maxStay           Int?
  closedToArrival   Boolean   @default(false)
  closedToDeparture Boolean   @default(false)
  isRefundable      Boolean   @default(true)
  isActive          Boolean   @default(true)

  hotel             Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomType          RoomType  @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([hotelId])
  @@index([roomTypeId])
}

model Inventory {
  id                String               @id @default(cuid())
  hotelId           String
  roomTypeId        String
  date              DateTime

  totalRooms        Int
  availableRooms    Int
  reservedRooms     Int                  @default(0)
  soldRooms         Int                  @default(0)
  blockedRooms      Int                  @default(0)

  baseRate          Decimal?             @db.Decimal(10, 2)
  minStay           Int                  @default(1)
  maxStay           Int?
  closedToArrival   Boolean              @default(false)
  closedToDeparture Boolean              @default(false)
  stopSell          Boolean              @default(false)

  blockReason       InventoryBlockReason @default(NONE)
  notes             String?

  hotel             Hotel                @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomType          RoomType             @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([roomTypeId, date])
  @@index([hotelId, date])
  @@index([roomTypeId, date])
  @@index([hotelId, roomTypeId, date])
}

model Booking {
  id                String               @id @default(cuid())
  hotelId           String
  roomTypeId        String

  externalBookingId String?
  bookingSource     BookingSourceType
  platformConfigId  String?

  guestName         String
  guestEmail        String?
  guestPhone        String?

  checkInDate       DateTime
  checkOutDate      DateTime
  nights            Int
  roomsBooked       Int                  @default(1)
  adults            Int                  @default(2)
  children          Int                  @default(0)

  totalAmount       Decimal?             @db.Decimal(10, 2)
  currency          String               @default("INR")

  status            BookingStatus        @default(CONFIRMED)
  rejectionReason   String?
  specialRequests   String?

  createdById       String?
  createdBy         User?                @relation("BookingCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  hotel             Hotel                @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomType          RoomType             @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  platformConfig    HotelPlatformConfig? @relation(fields: [platformConfigId], references: [id], onDelete: SetNull)

  bookingEvents     BookingEvent[]
  syncLogs          SyncLog[]

  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([hotelId])
  @@index([roomTypeId])
  @@index([platformConfigId])
  @@index([bookingSource])
  @@index([status])
  @@index([checkInDate, checkOutDate])
  @@unique([bookingSource, externalBookingId], map: "unique_external_booking_per_source")
}

model BookingEvent {
  id                String   @id @default(cuid())
  bookingId         String
  eventType         String
  message           String?
  payload           Json?

  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt         DateTime @default(now())

  @@index([bookingId])
  @@index([eventType])
}

model HotelPlatformConfig {
  id                String                   @id @default(cuid())
  hotelId           String
  platform          PlatformType
  status            PlatformConnectionStatus @default(PENDING)

  isEnabled         Boolean                  @default(true)
  externalHotelId   String?
  apiKey            String?
  apiSecret         String?
  accessToken       String?
  refreshToken      String?
  endpointUrl       String?

  lastSyncedAt      DateTime?
  lastErrorAt       DateTime?
  lastErrorMessage  String?

  settings          Json?

  hotel             Hotel                    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomMappings      RoomTypePlatformMapping[]
  syncLogs          SyncLog[]
  bookings          Booking[]
  reconciliationIssues SyncReconciliationIssue[]

  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@unique([hotelId, platform])
  @@index([hotelId])
  @@index([platform])
  @@index([status])
}

model RoomTypePlatformMapping {
  id                    String              @id @default(cuid())
  hotelPlatformConfigId String
  roomTypeId            String

  externalRoomTypeId    String
  externalRoomName      String?
  isActive              Boolean             @default(true)

  hotelPlatformConfig   HotelPlatformConfig @relation(fields: [hotelPlatformConfigId], references: [id], onDelete: Cascade)
  roomType              RoomType            @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([hotelPlatformConfigId, roomTypeId])
  @@index([roomTypeId])
  @@index([hotelPlatformConfigId])
}

model SyncLog {
  id                    String               @id @default(cuid())
  hotelId               String
  bookingId             String?
  hotelPlatformConfigId String?

  platform              PlatformType
  action                SyncActionType
  status                SyncStatus

  requestPayload        Json?
  responsePayload       Json?
  errorMessage          String?
  retryCount            Int                  @default(0)
  correlationId         String?
  idempotencyKey        String?

  hotel                 Hotel                @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  booking               Booking?             @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  hotelPlatformConfig   HotelPlatformConfig? @relation(fields: [hotelPlatformConfigId], references: [id], onDelete: SetNull)
  replayRequests        SyncReplayRequest[]

  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([hotelId])
  @@index([bookingId])
  @@index([hotelPlatformConfigId])
  @@index([platform, status])
  @@index([createdAt])
  @@index([correlationId])
}

model InventoryEvent {
  id                String   @id @default(cuid())
  hotelId           String
  roomTypeId        String?
  action            String
  message           String?
  payload           Json?

  hotel             Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  createdAt         DateTime @default(now())

  @@index([hotelId])
  @@index([roomTypeId])
  @@index([createdAt])
}

model OwnerProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  legalBusinessName String
  gstin             String
  pan               String
  contactPhone      String
  addressLine1      String
  addressLine2      String?
  city              String
  state             String
  country           String
  postalCode        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([gstin])
  @@index([pan])
}

model OwnerOnboarding {
  id              String           @id @default(cuid())
  userId          String           @unique
  status          OnboardingStatus @default(DRAFT)
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewedById    String?
  rejectionReason String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy      User?            @relation("OnboardingReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([reviewedById])
}

model PropertyRegistration {
  id                String           @id @default(cuid())
  ownerId           String
  hotelId           String           @unique
  status            OnboardingStatus @default(DRAFT)
  legalPropertyName String
  displayName       String
  slug              String           @unique
  description       String?
  addressLine1      String
  addressLine2      String?
  city              String
  state             String
  country           String
  postalCode        String
  contactEmail      String?
  contactPhone      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  owner             User             @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  hotel             Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  mediaAssets       MediaAsset[]     @relation("MediaProperty")

  @@index([ownerId])
  @@index([status])
}

model MediaAsset {
  id                     String          @id @default(cuid())
  ownerId                String?
  hotelId                String?
  propertyRegistrationId String?
  assetType              MediaAssetType
  visibility             MediaVisibility
  cloudinaryPublicId     String
  secureUrl              String
  version                Int?
  bytes                  Int?
  mimeType               String?
  metadata               Json?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  owner                  User?                 @relation("MediaOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  hotel                  Hotel?                @relation("MediaHotel", fields: [hotelId], references: [id], onDelete: SetNull)
  propertyRegistration   PropertyRegistration? @relation("MediaProperty", fields: [propertyRegistrationId], references: [id], onDelete: SetNull)

  @@unique([cloudinaryPublicId])
  @@index([ownerId])
  @@index([hotelId])
  @@index([assetType])
  @@index([propertyRegistrationId])
}

model ApprovalAuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  entityType  String
  entityId    String
  action      String
  beforeState Json?
  afterState  Json?
  createdAt   DateTime @default(now())

  actor       User?    @relation("ApprovalActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model IdempotencyKey {
  id            String            @id @default(cuid())
  key           String
  userId        String
  route         String
  method        String
  requestHash   String
  status        IdempotencyStatus @default(PROCESSING)
  responseCode  Int?
  responseBody  Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  expiresAt     DateTime

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([key, userId])
  @@index([status])
  @@index([expiresAt])
}

model SyncReconciliationRun {
  id            String               @id @default(cuid())
  hotelId       String
  triggeredById String?
  status        ReconciliationRunStatus @default(QUEUED)
  startedAt     DateTime             @default(now())
  finishedAt    DateTime?
  totalChecked  Int                  @default(0)
  issuesFound   Int                  @default(0)
  summary       Json?
  createdAt     DateTime             @default(now())

  hotel         Hotel                @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  triggeredBy   User?                @relation("ReconciliationTriggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull)
  issues        SyncReconciliationIssue[]

  @@index([hotelId])
  @@index([status])
  @@index([createdAt])
}

model SyncReconciliationIssue {
  id               String                    @id @default(cuid())
  runId            String
  hotelId          String
  platformConfigId String?
  roomTypeId       String?
  date             DateTime?
  expectedAvailable Int?
  actualAvailable  Int?
  severity         ReconciliationIssueSeverity @default(MEDIUM)
  status           ReconciliationIssueStatus @default(OPEN)
  payload          Json?
  resolvedAt       DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  run              SyncReconciliationRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  hotel            Hotel                     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  platformConfig   HotelPlatformConfig?      @relation(fields: [platformConfigId], references: [id], onDelete: SetNull)
  roomType         RoomType?                 @relation(fields: [roomTypeId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([hotelId])
  @@index([status])
  @@index([severity])
}

model SyncReplayRequest {
  id            String             @id @default(cuid())
  jobId         String
  hotelId       String
  syncLogId     String?
  requestedById String
  status        ReplayRequestStatus @default(REQUESTED)
  notes         String?
  requestedAt   DateTime           @default(now())
  processedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  hotel         Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  requestedBy   User               @relation("ReplayRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  syncLog       SyncLog?           @relation(fields: [syncLogId], references: [id], onDelete: SetNull)

  @@index([jobId])
  @@index([hotelId])
  @@index([status])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  channel   NotificationChannel @default(IN_APP)
  type      NotificationType
  title     String
  body      String
  readAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([type])
}
